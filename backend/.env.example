# ─────────────────────────────────────────────────────────────
# Civic Lens — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# REQUIRED — Google Gemini API key
# Used by all AI agents: placement quiz, lessons, level quizzes,
# curriculum generation, admin agent, and roadmap Q&A.
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL — Hugging Face API token
# Only needed for the direct /api/v1/llm/generate endpoint
# and if embedding_provider is set to "huggingface" in config/settings.json.
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your_huggingface_token_here
